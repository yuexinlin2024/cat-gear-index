---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryCard from "@/components/CategoryCard.astro";
import { categories } from "@/data/categories";
import { products } from "@/data/products";
---

<BaseLayout title="Care Topics" description="Browse care topics that support cat grooming, washing, litter-area upkeep, and practical home maintenance.">
  <section class="page-hero">
    <span class="eyebrow">Categories</span>
    <h1>Care topics organized for practical decision-making.</h1>
    <p>Each topic can support guides, tools, and product notes. Use them as content buckets for grooming, cleaning, odor control, and household upkeep.</p>
  </section>
  <section class="section">
    <div class="category-grid">
      {categories.map((category) => (
        <CategoryCard category={category} count={products.filter((product) => product.category === category.slug).length} />
      ))}
    </div>
  </section>
</BaseLayout>
