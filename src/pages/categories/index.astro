---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryCard from "@/components/CategoryCard.astro";
import { categories } from "@/data/categories";
import { products } from "@/data/products";
---

<BaseLayout title="Cat Gear Categories" description="Browse structured cat supplies categories including litter, boxes, fountains, feeders, carriers, trees, scratchers, and toys.">
  <section class="page-hero">
    <span class="eyebrow">Categories</span>
    <h1>Cat supplies organized by comparison fields.</h1>
    <p>Every category has a different buying problem. These pages define what to measure, what to verify, and which tools should support the decision.</p>
  </section>
  <section class="section">
    <div class="category-grid">
      {categories.map((category) => (
        <CategoryCard category={category} count={products.filter((product) => product.category === category.slug).length} />
      ))}
    </div>
  </section>
</BaseLayout>
