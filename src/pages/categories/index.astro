---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryCard from "@/components/CategoryCard.astro";
import { categories } from "@/data/categories";
import { products } from "@/data/products";
---

<BaseLayout title="Care Topics" description="Browse care topics that support cat grooming, washing, litter-area upkeep, and practical home maintenance.">
  <section class="page-hero">
    <span class="eyebrow">Care Topics</span>
    <h1>Browse the main care topics behind the site.</h1>
    <p>These topic pages organize grooming, cleanup, odor control, litter-area upkeep, and household-fit questions into repeatable content buckets.</p>
  </section>
  <section class="section">
    <div class="category-grid">
      {categories.map((category) => (
        <CategoryCard category={category} count={products.filter((product) => product.category === category.slug).length} />
      ))}
    </div>
  </section>
</BaseLayout>
