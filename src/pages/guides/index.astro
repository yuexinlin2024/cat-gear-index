---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GuideCard from "@/components/GuideCard.astro";
import { getCollection } from "astro:content";
import { toTimestamp } from "@/utils/dates";

const guides = (await getCollection("guides", ({ data }) => !data.draft)).sort(
  (a, b) => toTimestamp(b.data.updatedAt) - toTimestamp(a.data.updatedAt)
);
---

<BaseLayout title="Cat Grooming And Home Care Guides" description="Read practical cat grooming, washing, cleaning, and non-medical home care guides.">
  <section class="page-hero">
    <span class="eyebrow">Guides</span>
    <h1>Guides built around routines, cleanup, and practical care.</h1>
    <p>These pages target everyday search questions about washing, brushing, odor control, litter-area maintenance, and home setup without drifting into diagnosis or treatment advice.</p>
  </section>
  <section class="section">
    <div class="guide-grid">
      {guides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>
</BaseLayout>
