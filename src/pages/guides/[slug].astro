---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { formatDate } from "@/utils/dates";

export async function getStaticPaths() {
  const guides = await getCollection("guides", ({ data }) => !data.draft);

  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide }
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
const { title, description, category, readingTime, points, updatedAt } = guide.data;
const relatedGuides = (await getCollection("guides", ({ data }) => !data.draft))
  .filter((entry) => entry.slug !== guide.slug)
  .sort((a, b) => {
    const aScore = a.data.category === category ? 1 : 0;
    const bScore = b.data.category === category ? 1 : 0;
    return bScore - aScore;
  })
  .slice(0, 3);
---

<BaseLayout title={title} description={description} pathname={`/guides/${guide.slug}/`}>
  <article class="article-shell">
    <span class="eyebrow">{category} · {readingTime}</span>
    <h1>{title}</h1>
    <p class="lead">{description}</p>

    <section>
      <h2>Quick Take</h2>
      <ul>{points.map((point) => <li>{point}</li>)}</ul>
    </section>

    <Content />
    <p class="muted">Last updated: {formatDate(updatedAt)}</p>

    {relatedGuides.length > 0 && (
      <section>
        <h2>Related Guides</h2>
        <ul>
          {relatedGuides.map((entry) => (
            <li><a href={`/guides/${entry.slug}/`}>{entry.data.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
