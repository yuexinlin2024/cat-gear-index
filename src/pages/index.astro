---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryCard from "@/components/CategoryCard.astro";
import GuideCard from "@/components/GuideCard.astro";
import ProductCard from "@/components/ProductCard.astro";
import { getCollection } from "astro:content";
import { categories } from "@/data/categories";
import { products } from "@/data/products";
import { toTimestamp } from "@/utils/dates";

const featuredProducts = products.slice(0, 4);
const allGuides = (await getCollection("guides", ({ data }) => !data.draft)).sort(
  (a, b) => toTimestamp(b.data.updatedAt) - toTimestamp(a.data.updatedAt)
);
const latestGuides = allGuides.slice(0, 6);
const beginnerGuides = allGuides
  .filter((guide) => ["Beginner Care", "Routine Checklists"].includes(guide.data.category))
  .slice(0, 3);
const featuredTopics = categories.slice(0, 4);
---

<BaseLayout title="Cat Grooming And Home Care Guides" description="Practical cat grooming, bathing, cleaning, and home care routines with simple product notes and non-medical maintenance guidance.">
  <section class="hero-section">
    <div class="hero-copy">
      <span class="eyebrow">Cat grooming and home care</span>
      <h1>Simple grooming, cleaning, and home-care guidance for everyday cat owners.</h1>
      <p>Cat Gear Index is a practical content site for cat washing, brushing, litter-area upkeep, odor control, and small-home routines. We focus on daily care systems that stay clearly outside veterinary advice.</p>
      <div class="hero-actions">
        <a class="button primary" href="/guides/">Read Guides</a>
        <a class="button secondary" href="/categories/">Browse Care Topics</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="Site highlights">
      <div>
        <strong>8</strong>
        <span>care topics</span>
      </div>
      <div>
        <strong>{allGuides.length}</strong>
        <span>published guides</span>
      </div>
      <div>
        <strong>0</strong>
        <span>medical claims</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <span class="eyebrow">Care Topics</span>
      <h2>Start from a real daily care problem</h2>
      <p>The site is organized around recurring home-care problems: brushing, bathing, litter-area upkeep, odor control, cleanup, and practical apartment routines.</p>
    </div>
    <div class="category-grid">
      {featuredTopics.map((category) => (
        <CategoryCard category={category} count={products.filter((product) => product.category === category.slug).length} />
      ))}
    </div>
    <div class="section-link-row">
      <a class="button secondary" href="/categories/">View All Care Topics</a>
    </div>
  </section>

  <section class="section two-column">
    <div>
      <div class="section-heading align-left">
        <span class="eyebrow">Begin Here</span>
        <h2>Give new visitors a simple path into the site</h2>
        <p>New visitors usually need a starting routine, not a full library. These entry guides make the site easier to understand and easier to share.</p>
      </div>
      <div class="guide-grid compact-grid">
        {beginnerGuides.map((guide) => <GuideCard guide={guide} />)}
      </div>
    </div>
    <aside class="operation-panel">
      <h2>Editorial focus</h2>
      <ol>
        <li>Publish clear answers to narrow care questions.</li>
        <li>Build topic clusters around brushing, bathing, odor control, and cleanup.</li>
        <li>Use tools and product notes as supporting pages, not the core brand.</li>
        <li>Expand the categories that start getting search impressions first.</li>
      </ol>
    </aside>
  </section>

  <section class="section">
    <div class="section-heading">
      <span class="eyebrow">Latest Guides</span>
      <h2>Fresh articles for search and repeat visits</h2>
      <p>Keep publishing around routine questions, tools, cleanup, and small-home care. The goal is steady topic coverage, not one giant article.</p>
    </div>
    <div class="guide-grid">
      {latestGuides.map((guide) => <GuideCard guide={guide} />)}
    </div>
    <div class="section-link-row">
      <a class="button secondary" href="/guides/">View All Guides</a>
    </div>
  </section>

  <section class="section two-column">
    <div>
      <div class="section-heading align-left">
        <span class="eyebrow">Tools</span>
        <h2>Small utilities keep the site useful</h2>
        <p>Use simple tools for repeat visits and bookmark value. They support the content strategy without turning the site into a software product.</p>
      </div>
      <div class="tool-grid single-tool-grid">
        <a class="tool-card" href="/tools/litter-cost-calculator/">
          <span>01</span>
          <h2>Litter Cost Calculator</h2>
          <p>Estimate monthly and yearly litter cost by cat count, bag price, bag weight, and usage rate.</p>
        </a>
      </div>
    </div>
    <div>
      <div class="section-heading align-left">
        <span class="eyebrow">Product Notes</span>
        <h2>Supporting pages for tools and supplies</h2>
        <p>These pages can later carry product comparisons and affiliate links, but they should stay secondary to the main article library.</p>
      </div>
      <div class="product-grid compact">
        {featuredProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>
</BaseLayout>
