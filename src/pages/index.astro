---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryCard from "@/components/CategoryCard.astro";
import GuideCard from "@/components/GuideCard.astro";
import ProductCard from "@/components/ProductCard.astro";
import { getCollection } from "astro:content";
import { categories } from "@/data/categories";
import { products } from "@/data/products";
import { toTimestamp } from "@/utils/dates";

const featuredProducts = products.slice(0, 4);
const guides = (await getCollection("guides", ({ data }) => !data.draft))
  .sort((a, b) => toTimestamp(b.data.updatedAt) - toTimestamp(a.data.updatedAt))
  .slice(0, 4);
---

<BaseLayout title="Cat Grooming And Home Care Guides" description="Practical cat grooming, bathing, cleaning, and home care routines with simple product notes and non-medical maintenance guidance.">
  <section class="hero-section">
    <div class="hero-copy">
      <span class="eyebrow">Cat grooming and home care</span>
      <h1>Simple grooming, cleaning, and home-care guidance for everyday cat owners.</h1>
      <p>Cat Gear Index is shifting toward practical care content: bathing routines, brushing tools, litter-area upkeep, odor control, and easy household systems that do not cross into veterinary advice.</p>
      <div class="hero-actions">
        <a class="button primary" href="/guides/">Read Guides</a>
        <a class="button secondary" href="/tools/litter-cost-calculator/">Use A Tool</a>
      </div>
    </div>
    <div class="hero-panel" aria-label="Database highlights">
      <div>
        <strong>8</strong>
        <span>care topics to expand</span>
      </div>
      <div>
        <strong>3</strong>
        <span>return-visit tools planned</span>
      </div>
      <div>
        <strong>0</strong>
        <span>medical claims</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <span class="eyebrow">Topics</span>
      <h2>Keep the site grounded in practical care problems</h2>
      <p>The existing category structure still works as a topic map for tools, maintenance checklists, and product-supported care routines.</p>
    </div>
    <div class="category-grid">
      {categories.map((category) => (
        <CategoryCard category={category} count={products.filter((product) => product.category === category.slug).length} />
      ))}
    </div>
  </section>

  <section class="section two-column">
    <div>
      <div class="section-heading align-left">
        <span class="eyebrow">Product support</span>
        <h2>Products should support the article, not replace it</h2>
        <p>For this site model, content leads and products assist. Use product pages as supporting references for combs, wipes, shampoos, mats, fountains, litter tools, and cleaning supplies.</p>
      </div>
      <div class="product-grid compact">
        {featuredProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
    <aside class="operation-panel">
      <h2>First revenue path</h2>
      <ol>
        <li>Publish 20 to 30 original grooming and home-care guides.</li>
        <li>Link only a small number of relevant products inside those guides.</li>
        <li>Apply for AdSense after traffic and indexed pages start to build.</li>
        <li>Add affiliate links later on high-intent pages such as comb, dryer, mat, and odor-control recommendations.</li>
      </ol>
    </aside>
  </section>

  <section class="section">
    <div class="section-heading">
      <span class="eyebrow">Guides</span>
      <h2>Content pillars for search traffic</h2>
      <p>Focus on routines, tools, cleanup, and everyday household care questions people actually search for.</p>
    </div>
    <div class="guide-grid">
      {guides.map((guide) => <GuideCard guide={guide} />)}
    </div>
  </section>
</BaseLayout>
