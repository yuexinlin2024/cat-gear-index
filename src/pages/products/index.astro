---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProductCard from "@/components/ProductCard.astro";
import { products } from "@/data/products";
---

<BaseLayout title="Product Notes" description="Browse product notes that support cat grooming, cleaning, litter-area upkeep, and practical home care routines.">
  <section class="page-hero">
    <span class="eyebrow">Product Notes</span>
    <h1>Supporting product pages for practical care decisions.</h1>
    <p>These pages are supporting references for litter, boxes, fountains, feeders, carriers, and other household tools. Keep the article as the main entry point and use product pages as backup detail.</p>
  </section>
  <section class="section">
    <div class="product-grid">
      {products.map((product) => <ProductCard product={product} />)}
    </div>
  </section>
</BaseLayout>
