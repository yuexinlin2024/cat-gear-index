---
import type { CollectionEntry } from "astro:content";

type Props = {
  guide: CollectionEntry<"guides">;
};

const { guide } = Astro.props;
const { title, category, readingTime, description } = guide.data;
---

<article class="guide-card">
  <span>{category} · {readingTime}</span>
  <h3><a href={`/guides/${guide.slug}/`}>{title}</a></h3>
  <p>{description}</p>
</article>
